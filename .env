# ===============================
# Application
# ===============================
VITE_APP_NAME=CarRental
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production

# ===============================
# Currency
# ===============================
VITE_CURRENCY=₹
VITE_CURRENCY_CODE=INR
VITE_COUNTRY=India
VITE_LANGUAGE=en

# ===============================
# API
# ===============================
VITE_API_URL=https://your-backend.onrender.com
# For local development:
# VITE_API_URL=http://localhost:5000

# ===============================
# Company
# ===============================
VITE_COMPANY_NAME=CarRental
VITE_COMPANY_EMAIL=support@carrental.com
VITE_COMPANY_PHONE=+91 9876543210
VITE_COMPANY_ADDRESS=Pune, Maharashtra, India

# ===============================
# Social Links
# ===============================
VITE_FACEBOOK=https://facebook.com/carrental
VITE_INSTAGRAM=https://instagram.com/carrental
VITE_LINKEDIN=https://linkedin.com/company/carrental
VITE_TWITTER=https://twitter.com/carrental

# ===============================
# Booking
# ===============================
VITE_BOOKING_TAX=18
VITE_SERVICE_CHARGE=100
VITE_DELIVERY_CHARGE=0

# ===============================
# Maps
# ===============================
VITE_GOOGLE_MAP_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ===============================
# Images
# ===============================
VITE_DEFAULT_CAR_IMAGE=/images/default-car.png

# ===============================
# Authentication
# ===============================
VITE_JWT_STORAGE_KEY=carRentalToken
VITE_USER_STORAGE_KEY=carRentalUser

# ===============================
# Pagination
# ===============================
VITE_PAGE_SIZE=12

# ===============================
# Features
# ===============================
VITE_ENABLE_CHAT=true
VITE_ENABLE_PAYMENT=true
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_NOTIFICATIONS=true

# ===============================
# Razorpay (Optional)
# ===============================
VITE_RAZORPAY_KEY=YOUR_RAZORPAY_KEY

# ===============================
# Firebase (Optional)
# ===============================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=